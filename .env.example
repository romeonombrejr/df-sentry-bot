# DF SentryBot — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Brave Search API key
# Get yours at https://api.search.brave.com/ (free "Data for Good" plan)
BRAVE_API_KEY=your_brave_api_key_here

# Microsoft Teams Incoming Webhook URL (optional)
# In Teams: channel > ··· > Workflows > Post to a channel when a webhook request is received
# Leave blank to disable Teams alerts.
TEAMS_WEBHOOK_URL=

# People to @mention in Teams alerts (optional, direct version only)
# Format: DisplayName:AzureADObjectID — comma-separated for multiple people.
# Object IDs are found in Teams Admin Centre > Users, or Azure Portal > Azure AD > Users.
# Leave blank to send alerts without mentions.
# Example: TEAMS_MENTIONS=Romeo:8c0a1a67-50ce-4114-bb6c-da9c5dbcf6ca,Jane:9d1b2b78-61df-4cd2-a519-abcdef123456
TEAMS_MENTIONS=
